VITE_GITHUB_TOKEN=your_github_personal_access_token_here

# Kimchi API key for the AI assistant (https://kimchi.dev).
# IMPORTANT: do NOT prefix this with VITE_. The VITE_ prefix tells Vite
# to inline the value into the client bundle, which would leak the key to
# every visitor. This key is consumed by:
#   • vite.config.js (dev-server proxy, via loadEnv with empty prefix)
#   • netlify/functions/kimchi.js (production serverless function)
# Leave blank — the proxy will respond with HTTP 500 and the chat will
# surface a friendly "service unavailable" message.
KIMCHI_API_KEY=your_kimchi_api_key_here